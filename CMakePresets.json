{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "displayName": "Base Configuration",
      "description": "Common settings for all platforms",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "msvc-base",
      "displayName": "MSVC Base Configuration",
      "description": "Common MSVC Settings",
      "hidden": true,
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "toolset": "host=x64",
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "msvc-x64-debug",
      "displayName": "MSVC Win64 Debug",
      "description": "Debug configuration for Windows x64 using MSVC",
      "inherits": "msvc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "msvc-x64-release",
      "displayName": "MSVC Win64 Release",
      "description": "Release configuration for Windows x64 using MSVC",
      "inherits": "msvc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "ninja-debug",
      "displayName": "Ninja Debug",
      "description": "Debug configuration using Ninja",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "ninja-release",
      "displayName": "Ninja Release",
      "description": "Release configuration using Ninja",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "msvc-x64-debug",
      "displayName": "MSVC Win64 Debug",
      "configurePreset": "msvc-x64-debug",
      "configuration": "Debug"
    },
    {
      "name": "msvc-x64-release",
      "displayName": "MSVC Win64 Release",
      "configurePreset": "msvc-x64-release",
      "configuration": "Release"
    },
    {
      "name": "ninja-debug",
      "displayName": "Ninja Debug",
      "configurePreset": "ninja-debug",
      "configuration": "Debug"
    },
    {
      "name": "ninja-release",
      "displayName": "Ninja Release",
      "configurePreset": "ninja-release",
      "configuration": "Release"
    }
  ]
}
